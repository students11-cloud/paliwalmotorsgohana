		<script>
			function loadScriptsCallback() {
				var scripts = document.getElementsByTagName("script");
				for (var i = 0; i < scripts.length; i++) {
					if (scripts[i].dataset.src != null) {
						scripts[i].src = scripts[i].dataset.src;
					}
				}
			}

			function loadScripts() {
				window.requestIdleCallback
					? window.requestIdleCallback(loadScriptsCallback)
					: loadScriptsCallback()
			}
			if (document.readyState === "complete") {
				loadScripts()
			}
			else {
				window.addEventListener("load", loadScripts);
			}
		</script>
	<script>
		var cityAutocompleteAbTest = 50;
		window.__PLATFORM_ID__ = 1;
		window.APP_VERSION = 0;
		window.NEXT_VERSION = window.APP_VERSION;
		window.originalLocationPath = window.originalLocationPath || (window.location.protocol + '//' + window.location.hostname + window.location.pathname + window.location.search);
	</script>
		<script type="text/javascript">
			setTimeout(function () {
				var firebaseApp = document.createElement('script');
				firebaseApp.src = 'https://www.gstatic.com/firebasejs/8.4.3/firebase-app.js';
				firebaseApp.onload = function () {
					var firebaseMessaging = document.createElement('script');
					firebaseMessaging.src = 'https://www.gstatic.com/firebasejs/8.4.3/firebase-messaging.js';
					firebaseMessaging.defer = true;
					document.body.appendChild(firebaseMessaging);
				};
				document.body.appendChild(firebaseApp);

				if (window.navigator && navigator.serviceWorker) {
					navigator.serviceWorker.getRegistrations().then(registrations => {
						for (const registration of registrations) {
							if (registration.active && registration.active.scriptURL === `${window.location.origin}/~partytown/partytown-sw.js`) {
								registration.unregister();
							}
						}
					});
				}
			}, 8000);
		</script>
