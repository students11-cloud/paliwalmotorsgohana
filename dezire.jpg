<script type='text/javascript'>
  function isAbTestUrl() {
	const LOADING_SCRIPTS_ON_SCROLL_PATHNAME_REGEX = [
	  new RegExp("\/used\/$"),
	  new RegExp("\/used\/absure\/$"),
	  new RegExp("\/used\/([a-zA-Z0-9_-]+)\/absure\/$"),
	  new RegExp("\/used\/([a-zA-Z0-9_-]+)\/$"),
	  new RegExp("\/used\/([a-zA-Z0-9_-]+)\/([a-zA-Z0-9_-]+)\/([a-zA-Z0-9_-]+)\/$")];
	for (var count = 0; count < LOADING_SCRIPTS_ON_SCROLL_PATHNAME_REGEX.length; count++) {
	  if (LOADING_SCRIPTS_ON_SCROLL_PATHNAME_REGEX[count].test(window.location.pathname)) return true;
	}
	return false;
  }
  var isValidAbTestPathName = isAbTestUrl();
  var googletag = googletag || {};
  googletag.cmd = googletag.cmd || [];

  var gptRan = false;

  // commented to pause pubmatic ads
  var loadGpt = function () {
	// Check the gptRan flag
	if (!gptRan) {
	  gptRan = true;
	  var gads = document.createElement('script');
	  gads.defer = true;
	  var useSSL = 'https:' == document.location.protocol;
	  gads.src = (useSSL ? 'https:' : 'http:') + '//www.googletagservices.com/tag/js/gpt.js';
	  var node = document.getElementsByTagName('script')[0];
	  if (isValidAbTestPathName) {
		if (window._LOAD_SCRIPT_EVENT_) {
		  node.parentNode.insertBefore(gads, node);
		}
		else {
		  window.addEventListener("loadScriptsEvent", function () { node.parentNode.insertBefore(gads, node); }, false)
		}
	  }
	  else {
		window.addEventListener("load", function () { setTimeout(function () { node.parentNode.insertBefore(gads, node); }, 5000); }, false)
	  }
	}
  }
  loadGpt();
